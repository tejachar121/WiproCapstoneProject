spring.application.name=api-gateway
server.port=8088
spring.main.web-application-type=reactive
eureka.client.service-url.defaultZone=http://localhost:8761/eureka
eureka.client.webclient.enabled=true

spring.cloud.gateway.server.webflux.routes[0].id=auth-service
spring.cloud.gateway.server.webflux.routes[0].uri=http://auth-service
spring.cloud.gateway.server.webflux.routes[0].predicates[0]=Path=/auth/**,/users/**

spring.cloud.gateway.server.webflux.routes[1].id=order-service
spring.cloud.gateway.server.webflux.routes[1].uri=http://order-service
spring.cloud.gateway.server.webflux.routes[1].predicates[0]=Path=/api/**

spring.cloud.gateway.server.webflux.routes[2].id=delivery-service
spring.cloud.gateway.server.webflux.routes[2].uri=http://delivery-service
spring.cloud.gateway.server.webflux.routes[2].predicates[0]=Path=/delivery/**

spring.cloud.gateway.server.webflux.routes[3].id=admin-service
spring.cloud.gateway.server.webflux.routes[3].uri=http://admin-service
spring.cloud.gateway.server.webflux.routes[3].predicates[0]=Path=/admin/***